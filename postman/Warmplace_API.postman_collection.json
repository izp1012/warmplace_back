{
  "info": {
    "name": "Warmplace API",
    "description": "카프카 기반 메신저 서비스 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "인증 (Auth)",
      "item": [
        {
          "name": "회원가입",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/signup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"nickname\": \"테스트유저\"\n}"
            }
          }
        },
        {
          "name": "로그인",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "현재 사용자 정보 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ]
          }
        },
        {
          "name": "로그아웃",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "채팅 (Chat)",
      "item": [
        {
          "name": "1:1 메시지 전송",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/direct",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"senderName\": \"테스트유저\",\n  \"receiverId\": \"receiver123\",\n  \"content\": \"안녕하세요!\"\n}"
            }
          }
        },
        {
          "name": "그룹 메시지 전송",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/group",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"senderName\": \"테스트유저\",\n  \"roomId\": \"general\",\n  \"content\": \"그룹 메시지입니다!\"\n}"
            }
          }
        },
        {
          "name": "입력 중 알림 (1:1)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/typing",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"receiverId\": \"receiver123\",\n  \"isTyping\": true\n}"
            }
          }
        },
        {
          "name": "그룹 입력 중 알림",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/group/typing",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"roomId\": \"general\",\n  \"isTyping\": true\n}"
            }
          }
        },
        {
          "name": "그룹 채팅방 입장",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/join",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"senderName\": \"테스트유저\",\n  \"roomId\": \"general\"\n}"
            }
          }
        },
        {
          "name": "그룹 채팅방 퇴장",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/chat/leave",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"testuser\",\n  \"senderName\": \"테스트유저\",\n  \"roomId\": \"general\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "게시글 (Posts)",
      "item": [
        {
          "name": "게시글 생성",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/posts",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gallery\": { \"id\": 1 },\n  \"title\": \"테스트 게시글 제목\",\n  \"content\": \"테스트 게시글 내용입니다.\",\n  \"images\": []\n}"
            }
          }
        },
        {
          "name": "게시글 단건 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "갤러리별 게시글 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/posts/gallery/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "갤러리 생성",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/galleries",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"감성 카페\",\n  \"description\": \"아늑하고 따뜻한 카페 갤러리\",\n  \"coverImage\": \"https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=600&h=400&fit=crop\",\n  \"category\": \"카페\"\n}"
        }
      }
    }
  ]
}
